---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- We can link Google Fonts or local font fallbacks. For pure speed, we use a premium system font stack -->
  </head>
  <body class="bg-white text-gray-900 antialiased min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="border-b border-gray-100 sticky top-0 bg-white/95 backdrop-blur-md z-50">
      <div class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight font-serif text-black hover:opacity-80 transition-opacity">
          Seek Key <span class="font-sans font-light text-gray-500 text-sm ml-1">Publication</span>
        </a>
        <nav class="flex items-center space-x-6 text-sm font-medium text-gray-600">
          <a href="/" class="hover:text-black transition-colors">首页</a>
          <a href="#" class="hover:text-black transition-colors">关于专栏</a>
          <a href="#" class="px-4 py-1.5 bg-black text-white rounded-full text-xs font-semibold hover:bg-gray-800 transition-colors">订阅</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-4xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 py-8 bg-gray-50 text-center text-xs text-gray-400">
      <div class="max-w-4xl mx-auto px-4">
        <p>© 2026 Seek Key. Powered by Drupal API & Astro.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Premium Substack Serif Font Stack */
  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap');
  
  .font-serif {
    font-family: 'Lora', Georgia, Cambria, "Times New Roman", Times, "Noto Serif SC", serif;
  }
  
  .font-sans {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  }
</style>
