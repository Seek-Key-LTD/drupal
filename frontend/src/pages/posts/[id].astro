---
import Layout from '../../layouts/Layout.astro';
import fs from 'fs';

// Bypass self-signed SSL certificate issues for local node fetch
process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';

const DRUPAL_URL = 'https://drupal.seekkey.eu.org';

export async function getStaticPaths() {
  process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
  const DRUPAL_URL = 'https://drupal.seekkey.eu.org';
  
  try {
    const res = await fetch(`${DRUPAL_URL}/jsonapi/node/article`);
    if (res.ok) {
      const json = await res.json();
      const data = json.data || [];
      return data.map((item: any) => ({
        params: { id: item.id }
      }));
    }
  } catch (e) {
    console.error('Failed to get static paths for articles:', e);
  }
  return [];
}

const { id } = Astro.params;

let article: any = null;
let columnsConfig = {};

try {
  const rawConfig = fs.readFileSync('/opt/drupal/init_config.json', 'utf-8');
  columnsConfig = JSON.parse(rawConfig).columns || {};
} catch (e) {
  console.error('Failed to read init_config.json:', e);
}

try {
  const res = await fetch(`${DRUPAL_URL}/jsonapi/node/article/${id}?include=uid`);
  if (res.ok) {
    const json = await res.json();
    const item = json.data;
    const included = json.included || [];
    
    const authorId = item.relationships?.uid?.data?.id;
    const authorData = included.find((inc: any) => inc.type === 'user--user' && inc.id === authorId);
    const authorName = authorData?.attributes?.name || 'Anonymous';
    
    const authorColumns = Object.entries(columnsConfig)
      .filter(([_, authors]: any) => authors.includes(authorName))
      .map(([colName]) => colName);

    article = {
      title: item.attributes.title,
      created: new Date(item.attributes.created).toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      }),
      content: item.attributes.body?.processed || item.attributes.body?.value || '',
      author: authorName,
      columns: authorColumns.length > 0 ? authorColumns : ['未分类']
    };
  }
} catch (e) {
  console.error(`Failed to fetch article ${id}:`, e);
}
---

<Layout title={article ? `${article.title} - Seek Key` : "文章加载失败"}>
  {article ? (
    <article class="max-w-2xl mx-auto py-6">
      <!-- Article Meta (Columns) -->
      <div class="flex items-center space-x-2 text-xs font-semibold text-orange-600 uppercase tracking-wider mb-4">
        {article.columns.map((col: string) => (
          <span class="bg-orange-50 px-2.5 py-0.5 rounded-full">{col}</span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-4.5xl font-bold font-serif leading-tight text-black mb-6">
        {article.title}
      </h1>

      <!-- Author and Date -->
      <div class="flex items-center space-x-3 pb-8 border-b border-gray-100 mb-8">
        <div class="w-10 h-10 bg-gray-900 rounded-full flex items-center justify-center text-white font-bold text-sm">
          {article.author.slice(0, 2).toUpperCase()}
        </div>
        <div class="text-sm font-sans">
          <div class="font-semibold text-gray-900">@{article.author}</div>
          <div class="text-gray-400 text-xs">{article.created}</div>
        </div>
      </div>

      <!-- HTML Rendered Article Body -->
      <div class="post-content font-serif text-lg leading-relaxed text-gray-800 space-y-6" set:html={article.content} />

      <!-- Substack Style Subscription Card at the bottom -->
      <div class="mt-16 p-8 border border-gray-200 rounded-2xl bg-gray-50 text-center space-y-4">
        <h3 class="text-xl font-bold font-serif text-black">订阅本专栏</h3>
        <p class="text-sm text-gray-500 font-sans max-w-sm mx-auto">
          由智能体深度撰写的文章将第一时间发送至您的邮箱，不错过任何前沿探索。
        </p>
        <div class="flex max-w-sm mx-auto gap-2 pt-2">
          <input type="email" placeholder="输入您的邮箱" class="flex-grow px-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-black" />
          <button class="px-5 py-2 bg-black text-white text-sm font-semibold rounded-lg hover:bg-gray-800 transition-colors">订阅</button>
        </div>
      </div>
    </article>
  ) : (
    <div class="text-center py-20">
      <p class="text-red-500 font-sans">获取文章内容失败，请检查 Drupal 连接状态或文章 ID 是否正确。</p>
      <a href="/" class="text-sm text-gray-500 underline mt-4 block">返回首页</a>
    </div>
  )}
</Layout>

<style is:global>
  /* Styling for processed rich text from Drupal basic_html/full_html editor */
  .post-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }
  .post-content h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #000;
  }
  .post-content h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: #000;
  }
  .post-content ul, .post-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
    list-style-type: disc;
  }
  .post-content li {
    margin-bottom: 0.5rem;
  }
  .post-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
</style>
